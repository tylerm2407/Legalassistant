# --- Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Redis (optional — rate limiter fails open without it) ---
REDIS_URL=redis://localhost:6379

# --- CORS (comma-separated origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Web frontend (set for production) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Mailchimp (waitlist signup) ---
MAILCHIMP_API_KEY=                     # Mailchimp API key (Account → Extras → API keys)
MAILCHIMP_SERVER_PREFIX=               # Datacenter prefix, e.g. "us21" (from API key suffix)
MAILCHIMP_LIST_ID=                     # Audience/list ID (Audience → Settings → Audience ID)

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=sk_test_...              # Stripe secret key (Dashboard → Developers → API keys)
STRIPE_PUBLISHABLE_KEY=pk_test_...         # Stripe publishable key (safe for frontend)
STRIPE_WEBHOOK_SECRET=whsec_...            # Stripe webhook signing secret (Dashboard → Webhooks)
STRIPE_PRICE_ID_PERSONAL=price_...         # Price ID for $20/mo Personal plan
STRIPE_PRICE_ID_FAMILY=price_...           # Price ID for $35/mo Family plan

# --- OpenAI (required for chat + audio transcription) ---
OPENAI_API_KEY=sk-...                         # Required for GPT-4o chat and Whisper audio transcription

# --- Email export (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@casematelaw.com
