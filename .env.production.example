# =============================================================================
# CaseMate — Production Environment Configuration
# =============================================================================
# Copy to .env and fill in production values.
# NEVER commit the actual .env file. Only .env.example and .env.production.example.
# =============================================================================

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-...                   # Production Anthropic API key

# --- Supabase (required) ---
SUPABASE_URL=https://PRODUCTION.supabase.co    # Production Supabase project URL
SUPABASE_KEY=eyJ...                            # Supabase anon/public key
SUPABASE_ANON_KEY=eyJ...                       # Same as SUPABASE_KEY (alias for frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # Service role key (backend only, never expose)
SUPABASE_JWT_SECRET=...                        # JWT secret for token verification

# --- Redis (required in production) ---
REDIS_URL=redis://default:PASSWORD@HOST:6379   # Redis instance for rate limiting

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://casematelaw.com,https://www.casematelaw.com

# --- Frontend (build-time) ---
NEXT_PUBLIC_API_URL=https://api.casematelaw.com
NEXT_PUBLIC_SUPABASE_URL=https://PRODUCTION.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_APP_URL=https://casematelaw.com

# --- Stripe (required for payments) ---
STRIPE_SECRET_KEY=sk_live_...                  # Live Stripe secret key
STRIPE_PUBLISHABLE_KEY=pk_live_...             # Live Stripe publishable key
STRIPE_WEBHOOK_SECRET=whsec_...                # Production webhook signing secret
STRIPE_PRICE_ID_PERSONAL=price_...             # $20/mo Personal plan price ID
STRIPE_PRICE_ID_FAMILY=price_...               # $35/mo Family plan price ID

# --- Mailchimp ---
MAILCHIMP_API_KEY=...                          # Production Mailchimp API key
MAILCHIMP_SERVER_PREFIX=us21                   # Datacenter prefix
MAILCHIMP_LIST_ID=...                          # Production audience ID

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@casematelaw.com
SMTP_PASS=...                                  # App-specific password
SMTP_FROM=CaseMate <hello@casematelaw.com>

# --- Monitoring ---
SENTRY_DSN=https://...@sentry.io/...           # Sentry error tracking DSN
LOG_LEVEL=INFO                                 # Production log level (INFO or WARNING)

# --- App ---
APP_ENV=production
APP_VERSION=0.3.0
