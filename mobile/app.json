{
  "expo": {
    "name": "CaseMate",
    "slug": "casemate-legal-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "casemate",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0F0D23"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.casemate.legalassistant"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0D23"
      },
      "package": "com.casemate.legalassistant"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
