{
  "expo": {
    "name": "CaseMate",
    "slug": "casemate-legal-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "casemate",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.casemate.legalassistant"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "package": "com.casemate.legalassistant"
    },
    "plugins": ["expo-router"]
  }
}
